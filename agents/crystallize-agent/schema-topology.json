  "reference_spec": {
    "_note": "What each schema SHOULD look like using full Valibot best practices. Expressed as pseudo-Valibot (valid construct names, not runnable).",

    "shared/schemas.ts": {
      "purpose": "Single source of truth for all shared schemas. Every tool file imports from here.",
      "schemas": {
        "V_ANTIBODY_TYPE": "v.picklist([\"training_pull\", \"default_override\", \"bias_caught\"])",
        "V_ADJUSTMENT_DIRECTION": "v.picklist([\"widen_sigma\", \"narrow_sigma\", \"shift_mu_up\", \"shift_mu_down\"])",
        "V_DIMENSION": {
          "construct": "v.object",
          "fields": {
            "name": "v.pipe(v.string(), v.minLength(1), v.description(\"Latent dimension name\"))",
            "mu": "v.pipe(v.number(), v.description(\"Mean of the dimension's distribution\"))",
            "sigma": "v.pipe(v.number(), v.minValue(0), v.description(\"Standard deviation (must be non-negative)\"))",
            "description": "v.optional(v.pipe(v.string(), v.description(\"What this dimension measures\")))"
          }
        },
        "V_QUALITY_VECTOR": {
          "construct": "v.object",
          "fields": {
            "elbo": "v.pipe(v.number(), v.minValue(0), v.maxValue(1), v.description(\"Evidence Lower BOund — primary convergence metric\"))",
            "holistic": "v.pipe(v.number(), v.minValue(0), v.maxValue(1), v.description(\"Holistic quality score\"))",
            "accuracy": "v.pipe(v.number(), v.minValue(0), v.maxValue(1), v.description(\"Accuracy of decoded output vs input\"))",
            "complexity": "v.pipe(v.number(), v.minValue(0), v.maxValue(1), v.description(\"Complexity penalty\"))",
            "dimensions": "v.record(v.string(), v.pipe(v.number(), v.description(\"Per-dimension quality score\")))",
            "weakest": "v.optional(v.array(v.pipe(v.string(), v.minLength(1))))",
            "rejection_severity": "v.optional(v.pipe(v.number(), v.minValue(0), v.description(\"Severity of rejection signals detected\")))",
            "rejection_count": "v.optional(v.pipe(v.integer(), v.minValue(0), v.description(\"Number of rejection signals\")))"
          }
        },
        "V_ANTIBODY": {
          "construct": "v.object",
          "fields": {
            "pattern": "v.pipe(v.string(), v.minLength(1), v.description(\"Detected decoherence pattern\"))",
            "type": "v.pipe(V_ANTIBODY_TYPE, v.description(\"Classification of the decoherence\"))",
            "strength": "v.pipe(v.number(), v.minValue(0), v.maxValue(1), v.description(\"Antibody strength [0,1]\"))"
          }
        },
        "V_ADJUSTMENT": {
          "construct": "v.object",
          "fields": {
            "dimension": "v.pipe(v.string(), v.minLength(1), v.description(\"Dimension name to adjust\"))",
            "direction": "v.pipe(V_ADJUSTMENT_DIRECTION, v.description(\"How to adjust the dimension\"))",
            "magnitude": "v.pipe(v.number(), v.minValue(0), v.description(\"Magnitude of adjustment\"))"
          }
        },
        "V_TOKEN_USAGE": {
          "construct": "v.object",
          "fields": {
            "inputTokens": "v.pipe(v.integer(), v.minValue(0))",
            "outputTokens": "v.pipe(v.integer(), v.minValue(0))",
            "cacheReadTokens": "v.pipe(v.integer(), v.minValue(0))"
          }
        },
        "V_VERTEX": {
          "construct": "v.object",
          "fields": {
            "id": "v.pipe(v.string(), v.minLength(1), v.description(\"Vertex identifier\"))",
            "perspective": "v.pipe(v.string(), v.minLength(1), v.description(\"The perspective this vertex represents\"))",
            "survived": "v.pipe(v.boolean(), v.description(\"Whether this vertex survived pruning\"))",
            "reason": "v.pipe(v.string(), v.minLength(1), v.description(\"Why this vertex survived or was pruned\"))",
            "delta": "v.pipe(v.number(), v.description(\"Parallax delta — distance between training and evidence\"))",
            "edges": "v.optional(v.array(v.pipe(v.string(), v.minLength(1), v.description(\"Connected vertex ID\"))))"
          }
        }
      },
      "type_exports": {
        "Dimension": "v.InferOutput<typeof V_DIMENSION>",
        "QualityVector": "v.InferOutput<typeof V_QUALITY_VECTOR>",
        "Antibody": "v.InferOutput<typeof V_ANTIBODY>",
        "AdjustmentSignal": "v.InferOutput<typeof V_ADJUSTMENT>",
        "TokenUsage": "v.InferOutput<typeof V_TOKEN_USAGE>",
        "Vertex": "v.InferOutput<typeof V_VERTEX>",
        "AntibodyType": "v.InferOutput<typeof V_ANTIBODY_TYPE>",
        "AdjustmentDirection": "v.InferOutput<typeof V_ADJUSTMENT_DIRECTION>"
      }
    },

