{
  "name": "splice",
  "private": true,
  "version": "0.1.1",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.13.0",
  "workspaces": [
    "server",
    "webui"
  ],
  "scripts": {
    "gate": "bash checks/gate.sh",
    "gate:rules": "ast-grep scan && ast-grep test --skip-snapshot-tests",
    "test:hooks": "python3 .claude/hooks/tests/test_orchestrator.py",
    "oss:verify": "bash checks/oss/run.sh",
    "e2e:heads": "bash checks/e2e/heads-e2e.sh",
    "e2e:heads:wire": "bash checks/e2e/heads-e2e.sh --tier 1"
  },
  "devDependencies": {
    "@ast-grep/cli": "0.45.0"
  },
  "overrides": {
    "handlebars": "4.7.9"
  }
}
