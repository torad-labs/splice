diff --git a/bin/splice-launch b/bin/splice-launch
new file mode 100755
index 0000000..347a7e8
--- /dev/null
+++ b/bin/splice-launch
@@ -0,0 +1,52 @@
+#!/usr/bin/env bash
+# splice-launch — the wrapper the installed argv[0] symlinks (claudex, grok, …) exec.
+# All logic lives in the daemon; this shim does the version handshake, cold-starts the daemon
+# if down, POSTs /launch to get the exec recipe, and execs `env … claude …`.
+# Head is inferred from argv[0] (the symlink name) or $SPLICE_HEAD.
+set -euo pipefail
+
+HEAD="${SPLICE_HEAD:-$(basename "$0")}"
+[ "$HEAD" = "splice-launch" ] && HEAD="claudex"
+
+CONTROL_PORT="${SPLICE_CONTROL_PORT:-3096}"
+CONTROL="http://127.0.0.1:${CONTROL_PORT}"
+JAR="${SPLICE_JAR:-$HOME/.local/share/splice/splice.jar}"
+STATE_DIR="${CLAUDEX_STATE_DIR:-$HOME/.claude-codex/state}"
+KEY_FILE="${STATE_DIR}/mgmt-key"
+SAFE="false"
+[ "${CLAUDEX_SAFE:-0}" = "1" ] && SAFE="true"
+
+health() { curl -sS -m 2 "${CONTROL}/health" 2>/dev/null || true; }
+
+# Cold-start the daemon if it isn't answering.
+if [ -z "$(health)" ]; then
+  if [ ! -f "$JAR" ]; then
+    echo "splice: daemon jar not found at $JAR (run: splice install, or set SPLICE_JAR)" >&2
+    exit 1
+  fi
+  echo "splice: starting daemon…" >&2
+  nohup java -jar "$JAR" daemon >/dev/null 2>&1 &
+  for _ in $(seq 1 50); do [ -n "$(health)" ] && break; sleep 0.2; done
+fi
+
+KEY="$(cat "$KEY_FILE" 2>/dev/null || true)"
+if [ -z "$KEY" ]; then echo "splice: mgmt-key not found at $KEY_FILE" >&2; exit 1; fi
+
+# Ask the daemon for the exec recipe (env sets/unsets + argv), passing through extra args.
+ARGS_JSON="$(printf '%s\n' "$@" | python3 -c 'import sys,json; print(json.dumps([l.rstrip("\n") for l in sys.stdin if l.strip()!=""]))' 2>/dev/null || echo '[]')"
+RECIPE="$(curl -sS -X POST "${CONTROL}/launch/${HEAD}" \
+  -H "Authorization: Bearer ${KEY}" -H 'Content-Type: application/json' \
+  --data "{\"safe\":\"${SAFE}\",\"args\":${ARGS_JSON}}")"
+
+# Parse the recipe into env/unset/argv and exec.
+eval "$(printf '%s' "$RECIPE" | python3 - <<'PY'
+import sys, json, shlex
+r = json.load(sys.stdin)
+if "argv" not in r:
+    sys.stderr.write("splice: launch failed: " + json.dumps(r) + "\n"); sys.exit(1)
+sets = " ".join(f"{k}={shlex.quote(v)}" for k, v in r.get("env", {}).items())
+unsets = " ".join(f"-u {shlex.quote(k)}" for k in r.get("unset", []))
+argv = " ".join(shlex.quote(a) for a in r["argv"])
+print(f"exec env {unsets} {sets} {argv}")
+PY
+)"
