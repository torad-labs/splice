#!/usr/bin/env bash
# claudithos — Claude Code on Claude through the mythos memory-architecture
# proxy. EXPERIMENT TOOL: scratch/disposable tasks only.
# Arms: CLAUDITHOS_MODE=native|amnesia|mirror (default mirror).
set -euo pipefail
REPO="${CLAUDITHOS_ROOT:-$HOME/Documents/dev/projects/mythos/repo}"
NODE_BIN="${CLAUDEX_NODE:-$(command -v node)}"
[[ -n "$NODE_BIN" ]] || { echo "claudithos: node not found" >&2; exit 1; }
mapfile -d '' -t CMD < <("$NODE_BIN" "$REPO/server/launcher/ensure-proxy.mjs" claudithos "$@")
[[ ${#CMD[@]} -gt 0 ]] || { echo "claudithos: launcher failed (see messages above)" >&2; exit 1; }
exec env "${CMD[@]}"
