diff --git a/gateway/gradle/libs.versions.toml b/gateway/gradle/libs.versions.toml
new file mode 100644
index 0000000..548a389
--- /dev/null
+++ b/gateway/gradle/libs.versions.toml
@@ -0,0 +1,34 @@
+# Version catalog — single source of truth for the gateway build (P1-GRADLE).
+# Versions verified against repo1.maven.org maven-metadata 2026-07-16 (the solrsearch
+# index was stale — always check metadata <latest>, not search "latestVersion").
+[versions]
+kotlin = "2.3.21"
+ktor = "3.5.1"
+coroutines = "1.11.0"
+serialization = "1.11.0"
+ktoml = "0.7.1"
+konsist = "0.17.3"
+detekt = "1.23.8"
+junit = "6.1.2"
+
+[libraries]
+kotlinx-coroutines-core = { module = "org.jetbrains.kotlinx:kotlinx-coroutines-core", version.ref = "coroutines" }
+kotlinx-coroutines-test = { module = "org.jetbrains.kotlinx:kotlinx-coroutines-test", version.ref = "coroutines" }
+kotlinx-serialization-json = { module = "org.jetbrains.kotlinx:kotlinx-serialization-json", version.ref = "serialization" }
+ktoml-core = { module = "com.akuleshov7:ktoml-core", version.ref = "ktoml" }
+ktor-server-core = { module = "io.ktor:ktor-server-core", version.ref = "ktor" }
+ktor-server-netty = { module = "io.ktor:ktor-server-netty", version.ref = "ktor" }
+ktor-server-cio = { module = "io.ktor:ktor-server-cio", version.ref = "ktor" }
+ktor-server-sse = { module = "io.ktor:ktor-server-sse", version.ref = "ktor" }
+ktor-server-test-host = { module = "io.ktor:ktor-server-test-host", version.ref = "ktor" }
+ktor-client-core = { module = "io.ktor:ktor-client-core", version.ref = "ktor" }
+ktor-client-cio = { module = "io.ktor:ktor-client-cio", version.ref = "ktor" }
+konsist = { module = "com.lemonappdev:konsist", version.ref = "konsist" }
+junit-bom = { module = "org.junit:junit-bom", version.ref = "junit" }
+junit-jupiter = { module = "org.junit.jupiter:junit-jupiter" }
+junit-platform-launcher = { module = "org.junit.platform:junit-platform-launcher" }
+
+[plugins]
+kotlin-jvm = { id = "org.jetbrains.kotlin.jvm", version.ref = "kotlin" }
+kotlin-serialization = { id = "org.jetbrains.kotlin.plugin.serialization", version.ref = "kotlin" }
+detekt = { id = "io.gitlab.arturbosch.detekt", version.ref = "detekt" }
