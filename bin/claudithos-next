#!/usr/bin/env bash
# claudithos-next — the mythos v3 head on a SIDE PORT (:3096) for pre-cutover
# testing; the old claudithos on :3098 is untouched. Delete after cutover.
set -euo pipefail
REPO="${CLAUDITHOS_ROOT:-$HOME/Documents/dev/projects/mythos/repo}"
NODE_BIN="${CLAUDEX_NODE:-$(command -v node)}"
[[ -n "$NODE_BIN" ]] || { echo "claudithos-next: node not found" >&2; exit 1; }
export CLAUDITHOS_PORT="${CLAUDITHOS_PORT:-3096}"
mapfile -d '' -t CMD < <("$NODE_BIN" "$REPO/server/launcher/ensure-proxy.mjs" claudithos "$@")
[[ ${#CMD[@]} -gt 0 ]] || { echo "claudithos-next: launcher failed (see messages above)" >&2; exit 1; }
exec env "${CMD[@]}"
