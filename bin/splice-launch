#!/usr/bin/env bash
# splice-launch — the wrapper the installed argv[0] symlinks (claudex, grok, …) exec.
# All logic lives in the daemon; this shim does the version handshake, cold-starts the daemon
# if down, POSTs /launch to get the exec recipe, and execs `env … claude …`.
# Head is inferred from argv[0] (the symlink name) or $SPLICE_HEAD.
set -euo pipefail

HEAD="${SPLICE_HEAD:-$(basename "$0")}"
[ "$HEAD" = "splice-launch" ] && HEAD="claudex"

topology_control_port() {
  local config="${SPLICE_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/splice/splice.toml}"
  case "$config" in "~/"*) config="$HOME/${config#~/}" ;; esac
  [ -f "$config" ] || return 0
  awk '
    /^[[:space:]]*\[/ { in_daemon = ($0 ~ /^[[:space:]]*\[daemon\][[:space:]]*$/) }
    in_daemon && /^[[:space:]]*control_port[[:space:]]*=/ {
      sub(/^[^=]*=[[:space:]]*/, "")
      sub(/[[:space:]#].*$/, "")
      if ($0 ~ /^[0-9]+$/) { print; exit }
    }
  ' "$config"
}
CONTROL_PORT="${SPLICE_CONTROL_PORT:-$(topology_control_port)}"
CONTROL_PORT="${CONTROL_PORT:-3096}"
CONTROL="http://127.0.0.1:${CONTROL_PORT}"
JAR="${SPLICE_JAR:-${SPLICE_SHARE_DIR:-$HOME/.local/share/splice}/splice.jar}"
# Bounded heap by default (a 1000-stream fleet with unbounded per-stream buffers OOMs the JVM
# default); override with SPLICE_JVM_OPTS. Used for every daemon cold-start below.
# 1G→2G after the 2026-07-19 429 storm: ~650 concurrent SSE turns exhausted 1G even before the
# inflight cap existed; 2G rides out a full 48-inflight + 512-queue burst with headroom.
SPLICE_JVM_OPTS="${SPLICE_JVM_OPTS:--Xmx2048m -XX:+UseStringDeduplication -XX:G1PeriodicGCInterval=60000}"
STATE_DIR="${CLAUDEX_STATE_DIR:-$HOME/.claude-codex/state}"
KEY_FILE="${STATE_DIR}/mgmt-key"
# Safe by default: the daemon never adds --dangerously-skip-permissions unless explicitly told to.
# CLAUDEX_DANGEROUSLY_SKIP_PERMISSIONS=1 is the named opt-in here AND on the legacy Node shim —
# both paths are safe-by-default now; the old CLAUDEX_SAFE is accepted as a harmless no-op.
DANGEROUS="false"
[ "${CLAUDEX_DANGEROUSLY_SKIP_PERMISSIONS:-0}" = "1" ] && DANGEROUS="true"
# Hand-paired with splice.core.SHIM_VERSION (gateway/core/src/main/kotlin/splice/core/Versions.kt)
# — bump both together whenever this shim's behavior changes. No code generation.
SPLICE_SHIM_VERSION="shim-2"
# Hand-paired with splice.core.GATEWAY_VERSION. Release acceptance verifies the marker.
SPLICE_GATEWAY_VERSION="0.1.1"

need_jar() {
  if [ ! -f "$JAR" ]; then
    echo "splice: jar not found at $JAR (run: splice install, or set SPLICE_JAR)" >&2
    exit 1
  fi
}

# Invoked as `splice` (the admin command): pass every subcommand straight to the CLI
# (setup, status, dashboard, login <head>, install, …). The CLI self-manages the daemon.
if [ "$HEAD" = "splice" ]; then
  need_jar
  exec java -jar "$JAR" "$@"
fi

# `<command> login` runs the OAuth browser flow for this head directly (no daemon needed).
if [ "${1:-}" = "login" ]; then
  need_jar
  exec java -jar "$JAR" login "$HEAD"
fi

health() { curl -sS -m 2 "${CONTROL}/health" 2>/dev/null || true; }
health_field() {
  local field="$1"
  printf '%s' "$HEALTH_JSON" | python3 -c 'import sys, json
field = sys.argv[1]
try:
    data = json.loads(sys.stdin.read() or "{}")
except Exception:
    data = {}
print(data.get(field) or "")' "$field" 2>/dev/null || true
}

# A listener is valid only when it is splice and its version matches the installed JAR/shim.
# New daemons can shut themselves down cleanly for an automatic upgrade. Legacy daemons without
# that route fail loudly instead of silently serving an incompatible API forever.
HEALTH_JSON="$(health)"
if [ -n "$HEALTH_JSON" ]; then
  RUNNING_VERSION="$(health_field version)"
  if [ -z "$RUNNING_VERSION" ]; then
    echo "splice: port $CONTROL_PORT is occupied by a non-splice or malformed health endpoint" >&2
    exit 1
  fi
  if [ "$RUNNING_VERSION" != "$SPLICE_GATEWAY_VERSION" ]; then
    KEY="$(cat "$KEY_FILE" 2>/dev/null || true)"
    if [ -z "$KEY" ]; then
      echo "splice: daemon version $RUNNING_VERSION is stale, but $KEY_FILE is unavailable; stop it and retry" >&2
      exit 1
    fi
    echo "splice: replacing stale daemon $RUNNING_VERSION with $SPLICE_GATEWAY_VERSION…" >&2
    if ! curl -fsS -m 3 -X POST "${CONTROL}/api/daemon/shutdown" \
      -H "Authorization: Bearer ${KEY}" >/dev/null; then
      echo "splice: stale daemon cannot self-stop; terminate it once, then retry" >&2
      exit 1
    fi
    for ((i = 0; i < 50; i++)); do
      HEALTH_JSON="$(health)"
      [ -z "$HEALTH_JSON" ] && break
      sleep 0.2
    done
    if [ -n "$HEALTH_JSON" ]; then
      echo "splice: stale daemon did not stop within 10 seconds" >&2
      exit 1
    fi
  fi
fi

if [ -z "$HEALTH_JSON" ]; then
  if [ ! -f "$JAR" ]; then
    echo "splice: daemon jar not found at $JAR (run: splice install, or set SPLICE_JAR)" >&2
    exit 1
  fi
  echo "splice: starting daemon…" >&2
  # shellcheck disable=SC2086 # word-splitting of JVM opts is intentional
  nohup java $SPLICE_JVM_OPTS -jar "$JAR" daemon >/dev/null 2>&1 &
  for ((i = 0; i < 50; i++)); do
    HEALTH_JSON="$(health)"
    [ -n "$HEALTH_JSON" ] && break
    sleep 0.2
  done
fi
RUNNING_VERSION="$(health_field version)"
if [ "$RUNNING_VERSION" != "$SPLICE_GATEWAY_VERSION" ]; then
  echo "splice: daemon failed version handshake (expected $SPLICE_GATEWAY_VERSION, got ${RUNNING_VERSION:-<none>})" >&2
  exit 1
fi

# Non-fatal staleness check: warn (never block) when the installed shim's marker doesn't match
# what the running daemon expects. Diagnostic only — the actual exec below always proceeds.
WANT_SHIM="$(health_field wantShimVersion)"
if [ -n "$WANT_SHIM" ] && [ -n "$SPLICE_SHIM_VERSION" ] && [ "$WANT_SHIM" != "$SPLICE_SHIM_VERSION" ]; then
  echo "splice: WARNING — installed launch shim ($0) is stale (marker=$SPLICE_SHIM_VERSION, daemon expects=$WANT_SHIM). Run: splice install (or ./install.sh) to refresh it." >&2
fi

KEY="$(cat "$KEY_FILE" 2>/dev/null || true)"
if [ -z "$KEY" ]; then echo "splice: mgmt-key not found at $KEY_FILE" >&2; exit 1; fi

# Ask the daemon for the exec recipe (env sets/unsets + argv), passing through extra args.
ARGS_JSON="$(python3 -c 'import json,sys; print(json.dumps(sys.argv[1:]))' "$@")"
RECIPE="$(curl -sS -X POST "${CONTROL}/launch/${HEAD}" \
  -H "Authorization: Bearer ${KEY}" -H 'Content-Type: application/json' \
  --data "{\"dangerouslySkipPermissions\":\"${DANGEROUS}\",\"args\":${ARGS_JSON}}")"

# Parse the recipe into env/unset/argv and exec. The recipe rides in $RECIPE (env), NOT stdin —
# the heredoc is python's stdin (the script), so piping the recipe in would be swallowed.
CMD="$(SPLICE_RECIPE="$RECIPE" python3 <<'PY'
import os, json, shlex, sys
raw = os.environ.get("SPLICE_RECIPE", "")
try:
    r = json.loads(raw)
except Exception:
    sys.stderr.write("splice: launch failed (no recipe from daemon): " + (raw or "<empty>") + "\n"); sys.exit(1)
if "argv" not in r:
    sys.stderr.write("splice: launch failed: " + json.dumps(r) + "\n"); sys.exit(1)
sets = " ".join(f"{k}={shlex.quote(v)}" for k, v in r.get("env", {}).items())
unsets = " ".join(f"-u {shlex.quote(k)}" for k in r.get("unset", []))
argv = " ".join(shlex.quote(a) for a in r["argv"])
if r.get("warning"):
    sys.stderr.write("splice: " + r["warning"] + "\n")
print(f"exec env {unsets} {sets} {argv}")
PY
)" || exit 1
eval "$CMD"
