{
  "version": "2.0.0",
  "description": "Architect Agent evaluation. Tests decomposition quality, SDK compliance, hyperedge integrity, custom Output detection.",
  "cases": [
    {
      "id": "auth-system",
      "name": "User Authentication System",
      "input_file": "cases/auth-system.json",
      "assertions": [
        {
          "id": "req_coverage",
          "text": "Every spec requirement maps to at least 1 tool",
          "type": "deterministic"
        },
        {
          "id": "rej_coverage",
          "text": "Every rejection boundary maps to at least 1 invariant",
          "type": "deterministic"
        },
        {
          "id": "concern_granularity",
          "text": "No tool covers more than 3 concerns",
          "type": "deterministic"
        },
        {
          "id": "agent_cohesion",
          "text": "No agent has more than 7 tools",
          "type": "deterministic"
        },
        {
          "id": "coupling_integrity",
          "text": "No H>0.7 pairs split across agents",
          "type": "deterministic"
        },
        {
          "id": "type_completeness",
          "text": "Every read type has a writer",
          "type": "deterministic"
        },
        { "id": "coherence_threshold", "text": "Coherence score >= 0.7", "type": "deterministic" },
        {
          "id": "adapter_presence",
          "text": "Has adapter_in for OAuth providers",
          "type": "deterministic"
        },
        {
          "id": "validator_presence",
          "text": "Has validator for token validation",
          "type": "deterministic"
        },
        {
          "id": "code_parseable",
          "text": "inputSchemaCode fields parse as valid Valibot",
          "type": "deterministic"
        }
      ]
    },
    {
      "id": "ecommerce-cart",
      "name": "E-Commerce Shopping Cart with Checkout",
      "input_file": "cases/ecommerce-cart.json",
      "assertions": [
        {
          "id": "req_coverage",
          "text": "Every spec requirement maps to at least 1 tool",
          "type": "deterministic"
        },
        {
          "id": "rej_coverage",
          "text": "Every rejection boundary maps to at least 1 invariant",
          "type": "deterministic"
        },
        {
          "id": "hyperedge_integrity",
          "text": "Order+payment+inventory hyperedge not cut across agents",
          "type": "deterministic"
        },
        {
          "id": "hyperedge_detected",
          "text": "At least 1 shared_transaction hyperedge exists in coupling output",
          "type": "deterministic"
        },
        {
          "id": "atomicity_extracted",
          "text": "Concerns for order+payment+inventory have atomicity field set with type transaction",
          "type": "deterministic"
        },
        {
          "id": "atomic_transaction",
          "text": "Order creation, payment, and inventory deduction in same agent",
          "type": "deterministic"
        },
        {
          "id": "pricing_pure",
          "text": "Price calculation is type domain with state stateless",
          "type": "deterministic"
        },
        {
          "id": "notification_async",
          "text": "Notification concerns typed as event",
          "type": "deterministic"
        },
        {
          "id": "type_completeness",
          "text": "Every read type has a writer",
          "type": "deterministic"
        },
        { "id": "coherence_threshold", "text": "Coherence score >= 0.7", "type": "deterministic" }
      ]
    },
    {
      "id": "notification-pipeline",
      "name": "Multi-Channel Notification Pipeline",
      "input_file": "cases/notification-pipeline.json",
      "assertions": [
        {
          "id": "req_coverage",
          "text": "Every spec requirement maps to at least 1 tool",
          "type": "deterministic"
        },
        {
          "id": "rej_coverage",
          "text": "Every rejection boundary maps to at least 1 invariant",
          "type": "deterministic"
        },
        {
          "id": "adapter_independence",
          "text": "Each channel adapter is a separate concern",
          "type": "deterministic"
        },
        {
          "id": "routing_is_policy",
          "text": "Routing concern typed as policy with Output.choice",
          "type": "deterministic"
        },
        {
          "id": "template_is_transformer",
          "text": "Template rendering typed as transformer",
          "type": "deterministic"
        },
        {
          "id": "rate_limit_is_validator",
          "text": "Rate limiting typed as validator",
          "type": "deterministic"
        },
        {
          "id": "adapter_count",
          "text": "At least 4 adapter_out concerns for 4 channels",
          "type": "deterministic"
        },
        { "id": "coherence_threshold", "text": "Coherence score >= 0.7", "type": "deterministic" }
      ]
    },
    {
      "id": "story-builder",
      "name": "Torad Stories Story Building Agent",
      "input_file": "cases/story-builder.json",
      "assertions": [
        {
          "id": "req_coverage",
          "text": "Every spec requirement maps to at least 1 tool",
          "type": "deterministic"
        },
        {
          "id": "rej_coverage",
          "text": "Every rejection boundary maps to at least 1 invariant",
          "type": "deterministic"
        },
        {
          "id": "domain_present",
          "text": "Has domain concerns for narrative arc management",
          "type": "deterministic"
        },
        {
          "id": "persistence_adapter",
          "text": "Has adapter_out for PostgreSQL",
          "type": "deterministic"
        },
        {
          "id": "iterative_support",
          "text": "Architecture supports iterative refinement",
          "type": "llm_graded"
        },
        { "id": "coherence_threshold", "text": "Coherence score >= 0.7", "type": "deterministic" }
      ]
    }
  ],
  "cross_case_assertions": [
    {
      "id": "custom_output_detection",
      "text": "At least one case produces a tool with outputStrategy custom",
      "type": "cross_case"
    },
    {
      "id": "hyperedge_detection",
      "text": "Ecommerce cart produces at least 1 shared_transaction hyperedge",
      "type": "cross_case"
    },
    {
      "id": "atomicity_to_hyperedge",
      "text": "Ecommerce cart: atomicity fields on concerns produce he-atom-* hyperedges in COUPLE output",
      "type": "cross_case"
    },
    {
      "id": "model_tier_variation",
      "text": "Scaffolds use at least 2 different model tiers across agents",
      "type": "cross_case"
    }
  ],
  "variance_config": {
    "runs_per_case": 3,
    "partition_stability_threshold": 0.8,
    "max_cost_per_run_usd": 0.5
  },
  "meta_assertions": [
    {
      "id": "non_discriminating",
      "text": "Flag assertions that pass on ALL cases regardless of input"
    },
    {
      "id": "high_variance",
      "text": "Flag assertions that pass/fail inconsistently across runs of same case"
    },
    { "id": "always_fail", "text": "Flag assertions that fail on ALL cases" }
  ]
}
