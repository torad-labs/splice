+// PORT-OF: server/test/errors.test.mjs @ 4ca99f7 — the ordered cascade: overflow BEFORE auth
+// ("too many tokens" must never classify as auth — the v29 bug), rate/auth/5xx/4xx/fallback,
+// HTTP json extraction + html gateway branch, SSE parity, 502->529 remap, 2000-char cap.
+import org.junit.jupiter.api.Assertions.assertEquals
+import org.junit.jupiter.api.Assertions.assertTrue
+import org.junit.jupiter.api.Test
+import splice.core.turn.ErrorType
+import splice.spi.FailureSource
+import splice.spi.UpstreamFailureClassifier
+
+class UpstreamFailureClassifierTest {
+
+    private fun sse(text: String) = UpstreamFailureClassifier.classify(FailureSource.SSE, text)
+
+    private fun http(text: String, status: Int?) =
+        UpstreamFailureClassifier.classify(FailureSource.HTTP, text, status)
+
+    @Test
+    fun `overflow beats auth - the v29 ordering bug stays fixed`() {
+        val r = sse("request_error too many tokens in this request")
+        assertEquals(ErrorType.INVALID_REQUEST, r.type)
+        assertTrue(r.message.startsWith("prompt is too long: "))
+    }
+
+    @Test
+    fun `overflow phrasings rewrite to claude's compact trigger`() {
+        listOf(
+            "the context window is exhausted",
+            "maximum context reached",
+            "context_length_exceeded",
+            "exceeds the context",
+            "token limit reached",
+        ).forEach { text ->
+            val r = sse(text)
+            assertEquals(ErrorType.INVALID_REQUEST, r.type, text)
+            assertTrue(r.message.contains("prompt is too long"), text)
+        }
+        // already-anthropic phrasing passes through unprefixed
+        val passthrough = sse("prompt is too long: 210000 tokens > 200000 maximum")
+        assertTrue(passthrough.message.startsWith("prompt is too long: 210000"))
+    }
+
+    @Test
+    fun `rate limit by status or wording`() {
+        assertEquals(ErrorType.RATE_LIMIT, http("slow down", 429).type)
+        assertEquals(ErrorType.RATE_LIMIT, sse("You hit a rate-limit").type)
+        assertEquals(ErrorType.RATE_LIMIT, sse("quota exhausted for org").type)
+    }
+
+    @Test
+    fun `auth by status or wording - but never the bare word token`() {
+        assertEquals(ErrorType.AUTHENTICATION, http("nope", 401).type)
+        assertEquals(ErrorType.AUTHENTICATION, sse("token expired, re-login").type)
+        assertEquals(ErrorType.AUTHENTICATION, sse("Unauthorized").type)
+        // bare "token" wording that is really an overflow stays overflow
+        assertEquals(ErrorType.INVALID_REQUEST, sse("too many tokens").type)
+    }
+
+    @Test
+    fun `http json body extraction`() {
+        val r = http("""{"error":{"type":"server_error","message":"boom"}}""", 500)
+        assertEquals(ErrorType.API_ERROR, r.type)
+        assertEquals("boom", r.message)
+    }
+
+    @Test
+    fun `html gateway body becomes api_error with status`() {
+        val r = http("<html><body>Bad gateway</body></html>", 502)
+        assertEquals(ErrorType.API_ERROR, r.type)
+        assertTrue(r.message.contains("502"))
+    }
+
+    @Test
+    fun `status tiers - 5xx api_error, 4xx invalid_request, fallback api_error`() {
+        assertEquals(ErrorType.API_ERROR, http("oops", 503).type)
+        assertEquals(ErrorType.INVALID_REQUEST, http("bad shape", 422).type)
+        assertEquals(ErrorType.API_ERROR, sse("mystery failure").type)
+    }
+
+    @Test
+    fun `messages cap at 2000 chars`() {
+        val r = sse("x".repeat(5000))
+        assertEquals(2000, r.message.length)
+    }
+
+    @Test
+    fun `502 maps out as 529`() {
+        assertEquals(529, UpstreamFailureClassifier.mapOutStatus(502))
+        assertEquals(500, UpstreamFailureClassifier.mapOutStatus(500))
+    }
+}
